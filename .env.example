# API 监听端口（apps/api）
PORT=3000

# API 绑定地址（apps/api），本地开发一般用 0.0.0.0 便于容器/其它进程访问
HOST=0.0.0.0

# 日志级别（pino/应用日志），常见值：fatal|error|warn|info|debug|trace|silent
LOG_LEVEL=info

# Postgres 连接串（packages/db）
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/app

# Redis 连接串（BullMQ 队列 / 缓存），本仓库默认 Docker baseline 开启 Redis AUTH
REDIS_URL=redis://:123456@127.0.0.1:6379

# OpenCLI 可执行文件路径/命令（packages/sources 会调用它）
OPENCLI_BIN=opencli

# OpenCLI 单次命令超时（毫秒）
OPENCLI_TIMEOUT_MS=20000

# Redis 缓存 TTL（分钟）
CACHE_TTL_MINUTES=15

# BullMQ 队列前缀（用于同一 Redis 下隔离不同环境/项目）
QUEUE_PREFIX=devtrend

# Worker 轮询各数据源的 cron（BullMQ repeatable jobs）
# 语法：standard cron（分 时 日 月 周）
SOURCE_POLL_SO_CRON=*/20 * * * *
SOURCE_POLL_HN_CRON=*/20 * * * *
SOURCE_POLL_DEVTO_CRON=*/30 * * * *
SOURCE_POLL_OSSINSIGHT_CRON=*/30 * * * *

# runtime topic refresh cron
TOPIC_SEED_REFRESH_CRON=0 * * * *

# embedding provider
OLLAMA_EMBEDDING_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text-v2-moe
OLLAMA_EMBEDDING_DIMENSIONS=768
OLLAMA_EMBEDDING_TIMEOUT_MS=30000

# topic naming provider (Cloudflare Workers AI)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_MODEL=
CLOUDFLARE_ACCOUNT_ID=
